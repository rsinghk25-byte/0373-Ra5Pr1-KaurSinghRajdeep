<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">
<xsl:template match="/">
<html>
<head>
<title>Biblioteca</title>
<style> body { font-family: sans-serif; padding: 20px; } h1 { border-bottom: 2px solid #333; padding-bottom: 8px; } h2 { margin-top: 30px; color: #444; } ul { line-height: 2; } </style>
</head>
<body>

<h1>Biblioteca</h1>

<h2>Llibres</h2>
<ul>
<xsl:apply-templates select="/biblioteca/llibre"/>
</ul>

<h2>Revistes</h2>
<ul>
<xsl:apply-templates select="/biblioteca/revista"/>
</ul>
</body>
</html>
</xsl:template>

<xsl:template match="llibre">
<li>
<xsl:value-of select="titol"/>
—
<xsl:value-of select="autor"/>
(
<xsl:value-of select="any"/>
)
</li>
</xsl:template>

<xsl:template match="revista">
<li>
<xsl:value-of select="titol"/>
— Codi:
<xsl:value-of select="@codi"/>
(
<xsl:value-of select="mes"/>
<xsl:value-of select="any"/>
)
</li>
</xsl:template>
</xsl:stylesheet>